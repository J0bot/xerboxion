{
  "version": "1.0.0",
  "description": "Complete cross-project dependency graph for the Xerboxion ecosystem",
  "connections": [
    {
      "id": "c01",
      "from": "xerax",
      "to": "xerboxion-core",
      "type": "depends-on",
      "protocol": "PLC v0",
      "description": "xerax requires core runtime for process lifecycle and IPC bus registration"
    },
    {
      "id": "c02",
      "from": "cubion",
      "to": "xerboxion-core",
      "type": "depends-on",
      "protocol": "PLC v0",
      "description": "cubion storage ploxion registers and runs on core runtime"
    },
    {
      "id": "c03",
      "from": "room-map",
      "to": "xerboxion-core",
      "type": "depends-on",
      "protocol": "PLC v0",
      "description": "room-map requires core runtime for process management"
    },
    {
      "id": "c04",
      "from": "xerfarm",
      "to": "xerboxion-core",
      "type": "depends-on",
      "protocol": "PLC v0",
      "description": "xerfarm requires core runtime for scheduling and IPC"
    },
    {
      "id": "c05",
      "from": "galactic-architect",
      "to": "xerboxion-core",
      "type": "depends-on",
      "protocol": "PLC v0",
      "description": "galactic-architect registers on core runtime"
    },
    {
      "id": "c06",
      "from": "swarm-xerboxion",
      "to": "xerboxion-core",
